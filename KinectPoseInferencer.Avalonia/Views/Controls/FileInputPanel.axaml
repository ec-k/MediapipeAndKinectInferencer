<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KinectPoseInferencer.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="KinectPoseInferencer.Avalonia.Views.Controls.FileInputPanel"
             x:DataType="vm:MainWindowViewModel">

    <StackPanel>
        <StackPanel.Styles>
            <Style Selector="TextBox">
                <Setter Property="Height" Value="30.0"/>
            </Style>
            <Style Selector="Button">
                <Setter Property="Height" Value="30.0"/>
            </Style>
        </StackPanel.Styles>

        <!-- File input fields (Playback mode only) -->
        <Grid IsVisible="{Binding IsPlaybackMode}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="video" VerticalAlignment="Center" Margin="0,0,10,5"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding PlaybackControl.VideoFilePath}" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="input log" VerticalAlignment="Center" Margin="0,0,10,5"/>
            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding PlaybackControl.InputLogFilePath}" Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="meta"  VerticalAlignment="Center" Margin="0,0,10,30"/>
            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding PlaybackControl.MetaFilePath}" Margin="0,0,0,30"/>

            <Button Grid.Row="3" Grid.Column="0" Command="{Binding PlaybackControl.LoadFilesCommand}" HorizontalAlignment="Left" Width="80">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xED25;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Kinect inference option -->
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <CheckBox IsChecked="{Binding IsKinectInferenceEnabled}" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">Inference Body by Kinect</TextBlock>
        </StackPanel>
    </StackPanel>
</UserControl>
